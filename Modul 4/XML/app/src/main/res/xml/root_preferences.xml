<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory app:title="@string/pref_category_language_settings">
        <ListPreference
            app:defaultValue="en"
            app:entries="@array/language_names"
            app:entryValues="@array/language_codes"
            app:key="language"
            app:title="@string/pref_title_change_language"
            app:useSimpleSummaryProvider="true" />
    </PreferenceCategory>

</PreferenceScreen>